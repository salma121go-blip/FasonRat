{
  "name": "fasonrat-backend",
  "version": "3.0.1",
  "description": "FasonRat Backend - Fastify + better-sqlite3",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.1",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "geoip-lite": "^1.4.10",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
